[node name="Villagers" type="Node3D" parent="."]

[node name="OldManThomas" parent="Villagers" instance=ExtResource("17_villager")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -4.8, 0, 1.8)
villager_name = "Old Man Thomas"
wander_radius = 3.5
move_speed = 1.5
pause_min = 3.0
pause_max = 7.0
dialogue_lines = [
	"Ah, another warrior through Rosemere. Watch the north road.",
	"The forge keeps our village alive. Gareth's our best.",
	"Bandits grow bolder every season...",
	"Stay away from the troll caves, lad.",
	"I remember when Rosemere was just a hamlet."
]

[node name="Martha" parent="Villagers" instance=ExtResource("17_villager")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 4.8, 0, 4.2)
villager_name = "Martha"
wander_radius = 3.5
move_speed = 1.8
pause_min = 2.0
pause_max = 6.0
dialogue_lines = [
	"Hello there, traveler! Stay for a meal?",
	"If you need supplies, Elora's your woman.",
	"The church hasn't had a priest in years...",
	"Have you seen my cat? He wanders off.",
	"Those bandits stole my chickens last week!"
]

[node name="MerchantLeo" parent="Villagers" instance=ExtResource("17_villager")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 1.5, 0, -1.2)
villager_name = "Merchant Leo"
wander_radius = 3.5
move_speed = 2.2
pause_min = 1.5
pause_max = 4.0
dialogue_lines = [
	"Trade's been slow since the road got dangerous.",
	"Silver swords from Gareth are top quality.",
	"I heard Grok the Troll crushed a caravan last moon.",
	"Got some fine cloth, if you're interested.",
	"The inn's ale is the best south of the river."
]

[node name="Sprite3D" parent="Villagers/MerchantLeo"]
texture = ExtResource("19_merchant")

[node name="YoungWill" parent="Villagers" instance=ExtResource("17_villager")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -5.5, 0, 5.0)
villager_name = "Young Will"
wander_radius = 3.5
move_speed = 2.5
pause_min = 1.0
pause_max = 3.0
dialogue_lines = [
	"I'm gonna be a Witcher one day! Just you wait!",
	"Did you really fight those bandits? So cool!",
	"My pa says the troll's as big as a house!",
	"I found a rusty dagger near the old road...",
	"Can you teach me to fight? Please?"
]

