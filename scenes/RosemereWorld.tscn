[node name="OldManThomas" parent="Villagers" instance=ExtResource("17_villager")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -6, 0, 0)
villager_name = "Old Man Thomas"
wander_radius = 6.0
move_speed = 1.5
pause_min = 3.0
pause_max = 7.0
dialogue_lines = [
	"Ah, another warrior through Rosemere. Watch the north road.",
	"The forge keeps our village alive. Gareth's our best.",
	"Bandits grow bolder every season...",
	"Stay away from the troll caves, lad.",
	"I remember when Rosemere was just a hamlet."
]

[node name="Martha" parent="Villagers" instance=ExtResource("17_villager")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 10, 0, 6)
villager_name = "Martha"
wander_radius = 5.0
move_speed = 1.8
pause_min = 2.0
pause_max = 6.0
dialogue_lines = [
	"Hello there, traveler! Stay for a meal?",
	"If you need supplies, Elora's your woman.",
	"The church hasn't had a priest in years...",
	"Have you seen my cat? He wanders off.",
	"Those bandits stole my chickens last week!"
]

[node name="MerchantLeo" parent="Villagers" instance=ExtResource("17_villager")]
